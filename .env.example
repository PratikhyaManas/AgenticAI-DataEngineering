# ==============================================================================
# AgenticAI-DataEngineering — Local Developer Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it is listed in .gitignore.
#
# Usage:
#   cp .env.example .env          # then edit .env
#   make install                  # installs deps and activates hooks
#   make seed-local               # seeds local Delta tables
#   make test                     # runs all tests locally
# ==============================================================================

# ------------------------------------------------------------------------------
# Deployment environment: dev | test | prod
# Controls which catalog ({env}_lakehouse) and Azure resources are targeted.
# ------------------------------------------------------------------------------
LAKEHOUSE_ENV=dev

# ------------------------------------------------------------------------------
# Azure Databricks workspace
# These are only needed for Databricks Connect (remote cluster tests) and
# for running `make deploy-*`. For local-only Spark tests they are not required.
# ------------------------------------------------------------------------------
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<personal-access-token-or-service-principal-token>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_CATALOG=dev_lakehouse
DATABRICKS_CLUSTER_ID=<cluster-id-for-databricks-connect>

# ------------------------------------------------------------------------------
# ADLS Gen2 storage account
# ------------------------------------------------------------------------------
ADLS_STORAGE_ACCOUNT=<storage-account-name>
ADLS_LANDING_PATH=abfss://landing@<storage-account-name>.dfs.core.windows.net
ADLS_RAW_PATH=abfss://raw@<storage-account-name>.dfs.core.windows.net
ADLS_CURATED_PATH=abfss://curated@<storage-account-name>.dfs.core.windows.net
ADLS_GOLD_PATH=abfss://gold@<storage-account-name>.dfs.core.windows.net

# ------------------------------------------------------------------------------
# Azure Active Directory — Service Principal used by pipelines
# Needed for Terraform provisioning and Azure DevOps service connections.
# For local development use your personal Azure CLI credentials (az login).
# ------------------------------------------------------------------------------
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<service-principal-app-id>
AZURE_CLIENT_SECRET=<service-principal-secret>
AZURE_SUBSCRIPTION_ID=<azure-subscription-id>

# Azure AD App Registration for the Gold REST API (JWT validation)
AZURE_AD_AUDIENCE=api://<gold-api-app-registration-id>

# ------------------------------------------------------------------------------
# Azure OpenAI — used by DQ Remediation Agent and NL-to-SQL Agent
# ------------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ------------------------------------------------------------------------------
# OpenLineage data lineage backend
# Set OPENLINEAGE_TRANSPORT=console for local dev (prints events to stdout).
# Set OPENLINEAGE_TRANSPORT=http and provide a Marquez URL for integration tests.
# ------------------------------------------------------------------------------
OPENLINEAGE_TRANSPORT=console
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=lakehouse
OPENLINEAGE_API_KEY=

# ------------------------------------------------------------------------------
# Gold REST API (FastAPI)
# Used when running the API server locally with `make serve-api`
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,https://app.powerbi.com
MAX_QUERY_ROWS=10000
NL2SQL_ALLOWED_SCHEMAS=gold
ROLE_ANALYST_GROUP=<azure-ad-group-id-for-analysts>
ROLE_SCIENTIST_GROUP=<azure-ad-group-id-for-scientists>
ROLE_ADMIN_GROUP=<azure-ad-group-id-for-admins>

# ------------------------------------------------------------------------------
# Databricks Asset Bundle variables
# Used by `make deploy-dev` and `make deploy-prod` via databricks CLI.
# Override per-environment in the terminal before running make targets.
# ------------------------------------------------------------------------------
DEV_DATABRICKS_HOST=https://<dev-workspace>.azuredatabricks.net
DEV_STORAGE_ACCOUNT=<dev-storage-account>
TEST_DATABRICKS_HOST=https://<test-workspace>.azuredatabricks.net
TEST_STORAGE_ACCOUNT=<test-storage-account>
PROD_DATABRICKS_HOST=https://<prod-workspace>.azuredatabricks.net
PROD_STORAGE_ACCOUNT=<prod-storage-account>

# ------------------------------------------------------------------------------
# Terraform remote state backend
# Used by `make infra-plan` and `make infra-apply`
# ------------------------------------------------------------------------------
TF_STATE_RESOURCE_GROUP=rg-lakehouse-tfstate
TF_STATE_STORAGE_ACCOUNT=stlakehousetestate
TF_STATE_CONTAINER=tfstate

# ------------------------------------------------------------------------------
# Local Delta table paths (used by seed-local and integration tests)
# Override to point to a local directory for offline development.
# ------------------------------------------------------------------------------
LOCAL_DELTA_BASE=/tmp/lakehouse_dev
TEST_ENV=dev
